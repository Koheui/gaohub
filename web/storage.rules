rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // イベントのクリエイティブ(カバー画像・登壇者写真など)
    // 公開LPで使うため read は公開。write はイベントを持つ org のメンバーのみ。
    match /events/{eventId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.exists(
          /databases/(default)/documents/organizations/$(firestore.get(/databases/(default)/documents/events/$(eventId)).data.orgId)/members/$(request.auth.uid)
        );
    }

    // 申込時の確認書類(学生証等)。個人情報を含むため、クライアントからの
    // 直接アクセスは一切許可しない。書き込みは /api/checkout、閲覧は
    // /api/registrations/[id]/verification-url が、いずれもサーバー側
    // (Admin SDK、このルールの適用外)で org メンバー確認の上おこなう。
    match /registrations/{registrationId}/{fileName} {
      allow read, write: if false;
    }
  }
}
