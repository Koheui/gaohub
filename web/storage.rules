rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // イベントのアセット(カバー画像・登壇者写真・告知バナー等)
    // 閲覧は公開。書き込みはログイン済みユーザーかつ10MB以下の画像ファイル
    match /events/{eventId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 申込時の確認書類(学生証等)。個人情報を含むためクライアントからの直接アクセスは禁止
    match /registrations/{registrationId}/{fileName} {
      allow read, write: if false;
    }
  }
}
